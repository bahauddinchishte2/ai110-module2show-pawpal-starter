classDiagram
    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet) None
        +find_pet(name) Pet
        +get_all_tasks() list~Task~
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task) None
        +get_pending_tasks() list~Task~
    }

    class Task {
        +str title
        +str time
        +date due_date
        +int duration_minutes
        +str priority
        +str frequency
        +bool completed
        +mark_complete() None
        +create_next_occurrence() Task
    }

    class Scheduler {
        +Owner owner
        +get_today_tasks(today) list~Task~
        +sort_by_time(tasks) list~Task~
        +filter_by_pet(pet_name) list~Task~
        +filter_by_status(completed) list~Task~
        +detect_conflicts(tasks) list~str~
        +complete_task(task) Task
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler --> Owner : reads data from
    Scheduler --> Task : organizes
